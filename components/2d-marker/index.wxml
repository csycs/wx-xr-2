<xr-scene ar-system="modes:Marker" bind:ready="handleReady">
    <xr-assets bind:loaded="handleAssetsLoaded">
      <xr-asset-load
        type="video-texture"
        asset-id="video-marker"
        options="loop:true"
        src="{{videoSrc}}"
      />
      <xr-asset-material
        asset-id="mat"
        effect="simple"
        uniforms="u_baseColorMap: video-video-marker"
      />
    </xr-assets>

    <xr-node wx:if="{{loaded}}">
      <xr-ar-tracker
        mode="Marker"
        bind:ar-tracker-switch="handleTrackerSwitch"
        src="{{markerSrc}}"
      >
        <xr-mesh node-id="mesh-plane" geometry="plane" material="mat" />
      </xr-ar-tracker>
    </xr-node>

    <xr-camera clear-color="0.4 0.8 0.6 1" background="ar" is-ar-camera />
  </xr-scene>
